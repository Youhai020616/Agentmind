{
  "name": "agentmind",
  "version": "1.0.0",
  "description": "Agent Self-Learning Memory System — Make AI agents understand you better over time",
  "type": "module",
  "exports": {
    "./core": "./scripts/lib/index.ts",
    "./storage": "./scripts/lib/storage.ts",
    "./confidence": "./scripts/lib/confidence.ts",
    "./detector": "./scripts/lib/detector.ts",
    "./evolution": "./scripts/lib/evolution.ts",
    "./preferences": "./scripts/lib/preference-detector.ts",
    "./types": "./scripts/lib/types.ts"
  },
  "bin": {
    "agentmind": "./scripts/lib/cli.ts"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint scripts/lib/",
    "typecheck": "tsc --noEmit",
    "setup": "chmod +x scripts/*.sh && npm run build",
    "cli": "npx tsx scripts/lib/cli.ts"
  },
  "keywords": [
    "ai", "agent", "memory", "learning", "instinct", "evolution",
    "claude", "openclaw", "self-learning", "preferences"
  ],
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^2.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "tsx": "^4.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "author": "Youhai <youhai020616@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/Youhai020616/Agentmind"
  }
}
